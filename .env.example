# Anthropic API Key (get from console.anthropic.com)
ANTHROPIC_API_KEY=

# Reddit OAuth — create a "web" app at reddit.com/prefs/apps
# Set redirect URI to: http://localhost:8080
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REFRESH_TOKEN=  # auto-filled after first run

# Twitter/X — app → Keys and Tokens → Bearer Token
TWITTER_BEARER_TOKEN=
TWITTER_USERNAME=

# Facebook (long-lived user token from Graph API Explorer)
FACEBOOK_ACCESS_TOKEN=

# Instagram (your login credentials, used by instagrapi)
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# LinkedIn OAuth 2.0 — create an app at linkedin.com/developers
# Add products: "Sign In with LinkedIn using OpenID Connect" + "Share on LinkedIn"
# Set redirect URI to: http://localhost:8080
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=  # auto-filled after first run
