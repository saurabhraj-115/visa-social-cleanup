# Anthropic API Key (get from console.anthropic.com)
ANTHROPIC_API_KEY=

# Reddit credentials (get from reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# Twitter/X credentials (get from developer.twitter.com)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_USERNAME=

# Facebook (long-lived user token from Graph API Explorer)
FACEBOOK_ACCESS_TOKEN=

# Instagram (your login credentials, used by instagrapi)
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=
